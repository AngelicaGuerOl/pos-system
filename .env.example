DB_NAME=pos_db
DB_USER=pos_user
DB_PASSWORD=your_db_password
DB_PORT=5433

BACKEND_PORT=8080
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api

# Local store production publishing. Defaults keep NovaPOS reachable only from this computer.
NOVAPOS_BIND_ADDRESS=127.0.0.1
NOVAPOS_FRONTEND_PORT=80

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password
PGADMIN_PORT=5051

SPRING_PROFILES_ACTIVE=prod
# Generate a Base64 or Base64URL value with at least 32 random bytes.
JWT_SECRET=your_base64_jwt_secret
JWT_EXPIRATION_MINUTES=60
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=your_admin_password

OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=NovaPOS/1.0 (correo-de-contacto)
